# Base de datos
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# URL publica/base de la app
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
CLERK_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# API key que DriverApp espera en sus APIs expuestas
DRIVER_API_KEY="driver-secret-key"

# RiderApp
# En Etapa 2 se conserva como configuracion futura. El flujo actual usa mocks locales.
RIDER_APP_URL="https://proyecto-a-rider-repairdash.vercel.app/api"
RIDER_INTERNAL_API_KEY="12345"

# PaymentsApp
PAYMENTS_APP_URL="http://localhost:3000/api/mocks"
PAYMENTS_INTERNAL_API_KEY="dev-payments-key"

# FeedbackApp
FEEDBACK_APP_URL="http://localhost:3000/api/mocks/feedback"
FEEDBACK_INTERNAL_API_KEY="repairdash-feedback-secret"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="supabase-service-role-key"

# Simulador de solicitudes desde RiderApp
MOCK_RIDER_JOB_INTERVAL_MS="10000"

