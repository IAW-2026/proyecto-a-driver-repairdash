generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Driver {
  id            String               @id @default(cuid())
  nombre        String
  email         String               @unique
  telefono      String?
  status        DriverStatus         @default(OFFLINE)
  trabajos      Trabajo[]
  tiposServicio DriverTipoServicio[]
  creadoEn      DateTime             @default(now())
  actualizadoEn DateTime             @updatedAt
}

enum DriverStatus {
  OFFLINE
  ONLINE
  EN_TRABAJO
}

model Trabajo {
  id               String            @id @default(cuid())
  driverId         String
  driver           Driver            @relation(fields: [driverId], references: [id])
  riderId          String
  tipoServicioId   String
  tipoServicio     TipoServicio      @relation(fields: [tipoServicioId], references: [id])
  descripcion      String?
  direccion        String
  latitud          Float?
  longitud         Float?
  estado           TrabajoEstado     @default(PENDIENTE)
  montoEstimado    Decimal           @db.Decimal(10, 2)
  historialEstados HistorialEstado[]
  creadoEn         DateTime          @default(now())
  actualizadoEn    DateTime          @updatedAt

  @@index([driverId])
  @@index([riderId])
  @@index([tipoServicioId])
  @@index([estado])
}

enum TrabajoEstado {
  PENDIENTE
  ACEPTADO
  RECHAZADO
  EN_CAMINO
  EN_SERVICIO
  FINALIZADO
  CANCELADO
}

model HistorialEstado {
  id             String         @id @default(cuid())
  trabajoId      String
  trabajo        Trabajo        @relation(fields: [trabajoId], references: [id])
  estadoAnterior TrabajoEstado?
  estadoNuevo    TrabajoEstado
  motivo         String?
  creadoEn       DateTime       @default(now())

  @@index([trabajoId])
}

model TipoServicio {
  id              String               @id @default(cuid())
  nombre          String               @unique
  descripcion     String
  precioBase      Decimal              @db.Decimal(10, 2)
  creadoEn        DateTime             @default(now())
  actualizadoEn   DateTime             @updatedAt
  driverServicios DriverTipoServicio[] @ignore
  trabajos        Trabajo[]            @ignore
}

model DriverTipoServicio {
  id             String       @id @default(cuid())
  driverId       String
  driver         Driver       @relation(fields: [driverId], references: [id])
  tipoServicioId String
  tipoServicio   TipoServicio @relation(fields: [tipoServicioId], references: [id])
  creadoEn       DateTime     @default(now())

  @@unique([driverId, tipoServicioId])
  @@index([driverId])
  @@index([tipoServicioId])
}
